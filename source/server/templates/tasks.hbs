
<div class="main-container">

  <h1>{{i18n "titles.myTasks" default="My tasks"}}</h1>

  <section>
    <form class="form-control" method="GET" style="margin-bottom:.75rem; display:flex; gap:1rem; flex-wrap:wrap; align-items:center;">
      {{#if (test user.level "==" "admin")}}
      <label class="form-item">
        {{i18n "fields.owner" default="Owner"}}
        <select name="owner" onchange="this.form.submit()">
          <option value="mine" {{#if (test params.owner "==" "mine")}}selected{{/if}}>{{i18n "labels.mine" default="Mine"}}</option>
          <option value="all" {{#if (test params.owner "==" "all")}}selected{{/if}}>{{i18n "labels.all" default="All"}}</option>
        </select>
      </label>
      {{/if}}

      <label class="form-item">
        {{i18n "fields.type" default="Type"}}
        <input name="type" type="search" value="{{params.type}}" placeholder="eg. delayTask" />
      </label>

      <label class="form-item">
        {{i18n "fields.status" default="Status"}}
        <select name="status" onchange="this.form.submit()">
          <option value="all" {{#if (test params.status "==" "all")}}selected{{/if}}>{{i18n "labels.all" default="all"}}</option>
          <option value="success" {{#if (test params.status "==" "success")}}selected{{/if}}>{{i18n "labels.success" default="success"}}</option>
          <option value="error" {{#if (test params.status "==" "error")}}selected{{/if}}>{{i18n "labels.error" default="error"}}</option>
        </select>
      </label>

      <label class="form-item">
        {{i18n "fields.rootOnly" default="Scope"}}
        <select name="rootOnly" onchange="this.form.submit()">
          <option value="true" {{#if params.rootOnly}}selected{{/if}}>{{i18n "labels.rootsOnly" default="Roots only"}}</option>
          <option value="false" {{#unless params.rootOnly}}selected{{/unless}}>{{i18n "labels.allTasks" default="All tasks"}}</option>
        </select>
      </label>
    </form>
    {{#if tasks.length}}
      <table class="list-table tasks-table">
        <thead>
          <tr>
            <th>{{i18n "fields.ctime"}}</th>
            {{#if (test params.owner "==" "all") }}<th>{{i18n "fields.owner"}}</th>{{/if}}
            {{#unless params.rootOnly }}<th>{{i18n "fields.parent"}}</th>{{/unless}}
            <th>{{i18n "fields.scene"}}</th>
            <th>{{i18n "fields.type"}}</th>
            <th>{{i18n "fields.status"}}</th>
          </tr>
        </thead>
        <tbody>
          {{#each tasks}}
          <tr>
            <td class="col-ctime compact">{{dateString ctime}}</td>
            {{#if (test @root.params.owner "==" "all") }}<td  class="col-owner compact">{{owner}}</td>{{/if}}
            {{#unless @root.params.rootOnly }}
              <td class="col-parent compact">
                {{#if parent}}
                  <a href="./{{ parent }}">#{{ parent }}</a>
                {{else}}
                  &mdash;
                {{/if}}
              </td>
            {{/unless}}
            <td class="col-scene">
              {{#if scene}}
                <a href="/ui/scenes/{{encodeURIComponent scene}}">{{ scene }}</a>
              {{else}}
                &mdash;
              {{/if}}
            </td>
            <td class="col-type">
              <a href="/ui/tasks/{{task_id}}">
                {{type}}#{{task_id}}
              </a>
            </td>
            <td class="col-status compact" style="text-align: right">
              <a href="/ui/tasks/{{task_id}}" class="task-status task-status-large status-{{status}}" style="text-decoration: none">
                {{status}}
              </a>
            </td>

          </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <p style="color: var(--color-secondary)">{{i18n "labels.noTasks" default="No tasks found."}}</p>
    {{/if}}
  </section>

</div>
