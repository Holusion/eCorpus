<div class="grid-header task-title-bar">
  <h1>
    Task #{{root.task_id}} <span class="task-type sm-hidden">&mdash; {{root.type}}</span>
  </h1>

</div>

<div class="grid-toolbar">
  <div class="action-title-wrap">
    <h3>Status</h3>
    <span class="task-status task-status-large status-{{root.status}}">{{root.status}}</span>
  </div>
  {{#if warnCount}}
  <div class="action-title-wrap">
    <h3>{{i18n "labels.warnings" default="Warnings"}}</h3>
    <a href="?level=warn" class="warn-count">{{warnCount}}</a>
  </div>
  {{/if}}
  <time style="text-align: right" datetime="{{dateString root.ctime "iso"}}">{{dateString root.ctime}}</time>

</div>

<div class="grid-content task-summary">
  {{#if root.scene_id}}
    <h2>Scene: <a href="/ui/scenes/{{encodeURIComponent scene}}">{{scene}}</a></h2>
  {{/if}}
  <section>
    <h3>{{i18n "titles.taskTree"}}</h3>
    {{#if root.parent}}<h4>{{i18n "labels.childOf"}} <a href="/ui/tasks/{{root.parent}}">#{{root.parent}}</a></h4>{{/if}}
    <div class="task-tree">
      {{#each root.children }}
        {{> taskNode . }}
      {{/each}}
    </div>
    <details>
      <summary><h3 class="inline-heading">{{i18n "titles.taskData"}}</h3></summary>
      <pre class="task-data-box">{{taskData}}</pre>
    </details>
  </section>

  <section>
    <div class="logs-header">
      <h3>{{i18n "titles.logs" default="Logs"}} <small class="logs-count">({{logs.length}})</small></h3>
      <form class="form-item inline" method="GET">
        <label style="white-space: nowrap;">
          {{i18n "fields.minLevel" default="Min level"}}
        </label>
        <select name="level" autocomplete="off" onchange="this.form.submit()">
          <option value="debug" {{#if (test level "==" "debug" )}}selected{{/if}}>debug</option>
          <option value="log"   {{#if (test level "==" "log"   )}}selected{{/if}}>log</option>
          <option value="warn"  {{#if (test level "==" "warn"  )}}selected{{/if}}>warn</option>
          <option value="error" {{#if (test level "==" "error" )}}selected{{/if}}>error</option>
        </select>
      </form>
    </div>
    {{#if logs.length}}
    <div class="logs-table-wrap">
      <table class="list-table compact logs-table">
        <thead>
          <tr>
            <th>time</th>
            <th>task</th>
            <th>level</th>
            <th>message</th>
          </tr>
        </thead>
        <tbody>
          {{#each logs}}
          <tr id="log-{{log_id}}" class="log-{{severity}}">
            <td class="log-time">{{dateString timestamp}}</td>
            <td class="log-task-id">#{{task_id}}</td>
            <td class="log-level log-{{severity}}">{{severity}}</td>
            <td class="log-message">{{message}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{else}}
      <p class="no-logs">{{i18n "labels.noLogs" default="No logs."}}</p>
    {{/if}}
  </section>

  <section class="task-output-section">
    <div class="task-output-actions">
      <a class="btn btn-outline btn-secondary" href="/tasks/{{root.task_id}}/artifact" download="task-{{root.task_id}}.zip">
        {{i18n "buttons.getTaskArtifacts"}}
      </a>
    </div>

    {{#if (test taskOutputType "==" "undefined")}}
      <p>{{i18n "leads.noOutput"}}</p>
    {{else if (test taskOutputType "==" "error") }}
      <h3 class="text-error">{{#if root.output.name}}{{ root.output.name}}{{else}}Error{{/if}}:</h3>
      <pre class="task-data-box">{{#if root.output.stack}}
        {{root.output.stack}}
      {{else}}
        {{root.output.message}}
      {{/if}}</pre>
    {{else}}
      <div class="task-output-header">
        <h3>{{i18n "titles.taskOutput"}}:</h3>
        <span class="task-status status-outline">{{taskOutputType}}</span>
      </div>
      <pre class="task-data-box">{{taskOutput}}</pre>
    {{/if}}
  </section>
</div>

{{!-- Recursive partial for task nodes --}}
{{#*inline "taskNode"}}
<div class="task-node">
  <div class="task-header">
    <a href="/ui/tasks/{{task_id}}" class="task-id">#{{task_id}}</a>
    <span class="task-type">{{type}}</span>
    <span class="task-status status-{{status}}">{{status}}</span>
  </div>
  {{#if children.length}}
  <div class="task-children">
    {{#each children}}
      {{> taskNode this}}
    {{/each}}
  </div>
  {{/if}}
</div>
{{/inline}}
