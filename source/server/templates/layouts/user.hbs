{{#> main }}
  <h1 class="grid-header">{{i18n "titles.userSettings"}}</h1>

  <div class="grid-toolbar">
    <nav id="user-profile-select">
      {{#navLink "/ui/user/" "exact"}}<ui-icon name="users"></ui-icon> {{i18n "nav.settings"}}{{/navLink}}
      {{#navLink "/ui/user/groups" "exact"}}<ui-icon name="groups"></ui-icon> {{i18n "nav.userGroups"}}{{/navLink}}
      {{#navLink "/ui/user/archives" "exact"}}<ui-icon name="folder" style="display:flex"></ui-icon> {{i18n "nav.userArchives"}}{{/navLink}}
      {{#navLink "/ui/user/tasks" "exact"}}<ui-icon name="tools"></ui-icon> {{i18n "nav.tasks"}}{{/navLink}}
    </nav>
  </div> 
  <div class="grid-content">
    {{{body}}}
  </div>

{{/main}}