
<section class="section-column">
  {{#if @root.user}}
  <div class="col" id="scene-permissions-container">
    <h3>
      {{i18n "titles.permissions"}}
    </h3>
    <div class="list-table-wrap">
      <table class="list-table compact form-control">
        <colgroup>
          <col span="1" style="width: 50%;">
          <col span="1" style="width: 50%;">
        </colgroup>
        <thead>
          <tr>
            <th>{{i18n "labels.group"}}</th>
            <th>
              {{i18n "labels.rights"}}
              {{#> popover id="permissions-tooltip" }}{{i18n "tooltips.permissions"}}{{/popover}}
            </th>
          </tr>
        </thead>
        <tbody>
          {{#*inline "showName"}}
          {{#if username}}
          {{username}}
          {{else}}
          {{groupName}}
          {{/if}}
          {{/inline}}

          <tr>
            {{#if (test @root.access "!=" "admin") }}
              <td class="text-main" title="{{i18n "labels.publicAccess"}}">{{i18n "labels.publicAccess"}}</td>
              <td class="text-main" >{{i18n (join "fields." @root.scene.public_access) @root.scene.public_access}}</td>
            {{else }}
              <td title="{{i18n "labels.username"}}">{{i18n "labels.publicAccess"}}</td>
              <td class="form-control">
                <submit-fragment style="display:flex;flex-direction: row-reverse;" submit="public_access" method="PATCH" action="/scenes/{{encodeURIComponent @root.scene.name}}"  encoding="application/json" onsubmit="window.location.reload()">
                  <form class="form-control" style="flex-grow: 1;" autocomplete="off">
                    <div class="form-item">
                      <select name="public_access" aria-label="{{i18n "labels.permission"}}">
                        {{> inputs/option selected=(test "none" "in" @root.scene.public_access) value="none" text=(i18n "fields.none")}}
                        {{#if (test @root.scene.default_access "==" "none")}}
                          {{> inputs/option selected=(test "read" "in" @root.scene.public_access) value="read" text=(i18n "fields.read") disabled=true}}
                        {{else}}
                          {{> inputs/option selected=(test "read" "in" @root.scene.public_access) value="read" text=(i18n "fields.read")}}
                        {{/if}}
                      </select>
                    </div>
                  </form>
                  <progress slot="loader" style="position:absolute; inset: 0;backdrop-filter: blur(5px)">request in progress</progress>
                </submit-fragment>
              </td>
            {{/if}}
          </tr>

          <tr>
            {{#if (test @root.access "!=" "admin") }}
              <td class="text-main" title="{{i18n "labels.defaultAccess"}}">{{i18n "labels.defaultAccess"}}</td>
              <td class="text-main" >{{i18n (join "fields." @root.scene.default_access) @root.scene.default_access}}</td>
            {{else }}
              <td title="{{i18n "labels.username"}}">{{i18n "labels.defaultAccess"}}</td>
              <td class="form-control">
                <submit-fragment style="display:flex;flex-direction: row-reverse;" submit="default_access" method="PATCH" action="/scenes/{{encodeURIComponent @root.scene.name}}"  encoding="application/json" onsubmit="window.location.reload()">
                  <form class="form-control" style="flex-grow: 1;" autocomplete="off">
                    <div class="form-item">
                      <select name="default_access" aria-label="{{i18n "labels.permission"}}">
                        {{#if (test @root.scene.public_access "==" "read")}}
                        {{> inputs/option selected=(test "none" "in" @root.scene.default_access) text=(i18n "fields.none") disabled=true}}
                        {{else}}
                        {{> inputs/option selected=(test "none" "in" @root.scene.default_access) value="none" text=(i18n "fields.none")}}
                        {{/if}}
                        {{> inputs/option selected=(test "read" "in" @root.scene.default_access) value="read" text=(i18n "fields.read")}}
                        {{> inputs/option selected=(test "write" "in" @root.scene.default_access) value="write" text=(i18n "fields.write")}}
                      </select>
                    </div>
                  </form>
                  <progress slot="loader" style="position:absolute; inset: 0;backdrop-filter: blur(5px)">request in progress</progress>
                </submit-fragment>
              </td>
            {{/if}}
          </tr>

          {{#each groupPermissions}}
          <tr>
            {{#if (test @root.access "!=" "admin") }}
            <td class="text-main" title="{{i18n "labels.group"}}">{{groupName}}</td>
            <td class="text-main">{{i18n (join "fields." access) access}} </td>
            {{else if (test (test username "==" @root.user.username) "&&" (test "!" (test @root.user.level "=="
            "admin")))}}
            <td class="text-primary" title="{{i18n "labels.group"}}">{{groupName}}</td>
            <td class="text-muted" title="{{i18n "leads.canNotChangeSelfAccess"}}">{{i18n (join "fields." access)
              access}}</td>
            {{else }}
            <td title="{{i18n "labels.group"}}">{{groupName}}</td>
            <td class="form-control">
              <submit-fragment style="display:flex;flex-direction: row-reverse;" submit="access" method="PATCH"
                action="/auth/access/{{encodeURIComponent @root.scene.name}}" encoding="application/json"
                onsubmit="window.location.reload()">
                <form class="form-control" style="flex-grow: 1;" autocomplete="off">
                  <input type="hidden" name="groupName" value="{{groupName}}" />
                  <div class="form-item">
                    <select name="access" aria-label="{{i18n "labels.permission"}}">
                      {{> inputs/option selected=(test "none" "in" access) value="none" text=(i18n
                      "fields.removeSpecificAccess")}}
                      {{> inputs/option selected=(test "read" "in" access) value="read" text=(i18n "fields.read")}}
                      {{> inputs/option selected=(test "write" "in" access) value="write" text=(i18n "fields.write")}}
                      {{> inputs/option selected=(test "admin" "in" access) value="admin" text=(i18n "fields.admin")}}
                    </select>
                  </div>
                </form>
                <progress slot="loader" style="position:absolute; inset: 0;backdrop-filter: blur(5px)">request in
                  progress</progress>
              </submit-fragment>
            </td>
            {{/if}}
          </tr>
          {{/each}}
          {{#if (test access "==" "admin")}}
          <tr>
            <td colspan="2">
              <submit-fragment class="form-control" id="scene_submit_fragment"
                style="display:flex;flex-direction: column-reverse;" submit="access" method="PATCH"
                action="/auth/access/{{encodeURIComponent @root.scene.name}}" encoding="application/json"
                onsubmit="window.location.reload()">
                <form class="form-group" style="flex-grow: 1;" autocomplete="off">
                  <div class="form-group row" style="align-items: stretch">
                    <input name="groupName" placeholder="{{i18n "labels.group"}}" required style="flex-grow: 1"/>
                    <select name="access" aria-label="{{i18n "labels.permission"}}" style="flex-grow: 1">
                      <option disabled selected value> -- select an option -- </option>
                      {{> inputs/option selected=false value="read" text=(i18n "fields.read")}}
                      {{> inputs/option selected=false value="write" text=(i18n "fields.write")}}
                      {{> inputs/option selected=false value="admin" text=(i18n "fields.admin")}}
                    </select>
                  </div>
                </form>
                <progress slot="loader" style="position:absolute; inset: 0;backdrop-filter: blur(5px)">request in
                  progress</progress>
              </submit-fragment>
            </td>
          </tr>
          {{/if}}

          <tr>
            <th>{{i18n "labels.username"}}</th>
            <th>
              {{i18n "labels.rights"}}
              {{#> popover id="permissions-tooltip" }}{{i18n "tooltips.permissions"}}{{/popover}}
            </th>
          </tr>

          {{#each userPermissions}}
          <tr>
            {{#if (test @root.access "!=" "admin") }}
            <td class="text-main" title="{{i18n "labels.username"}}">{{username}}</td>
            <td class="text-main">{{i18n (join "fields." access) access}} </td>
            {{else if (test (test username "==" @root.user.username) "&&" (test "!" (test @root.user.level "=="
            "admin")))}}
            <td class="text-primary" title="{{i18n "labels.username"}}">{{> showName}}</td>
            <td class="text-muted" title="{{i18n "leads.canNotChangeSelfAccess"}}">{{i18n (join "fields." access)
              access}}</td>
            {{else }}
            <td title="{{i18n "labels.username"}}">{{> showName}}</td>
            <td class="form-control">
              <submit-fragment style="display:flex;flex-direction: row-reverse;" submit="access" method="PATCH"
                action="/auth/access/{{encodeURIComponent @root.scene.name}}" encoding="application/json"
                onsubmit="window.location.reload()">
                <form class="form-control" style="flex-grow: 1;" autocomplete="off">
                  <input type="hidden" name="username" value="{{username}}" />
                  <div class="form-item">
                    <select name="access" aria-label="{{i18n "labels.permission"}}">
                      {{> inputs/option selected=(test "none" "in" access) value="none" text=(i18n
                      "fields.removeSpecificAccess")}}
                      {{> inputs/option selected=(test "read" "in" access) value="read" text=(i18n "fields.read")}}
                      {{> inputs/option selected=(test "write" "in" access) value="write" text=(i18n "fields.write")}}
                      {{> inputs/option selected=(test "admin" "in" access) value="admin" text=(i18n "fields.admin")}}
                    </select>
                  </div>
                </form>
                <progress slot="loader" style="position:absolute; inset: 0;backdrop-filter: blur(5px)">request in
                  progress</progress>
              </submit-fragment>
            </td>
            {{/if}}
          </tr>
          {{/each}}
          {{#if (test access "==" "admin")}}
          <tr>
            <td colspan="2">
              <submit-fragment class="form-control" id="scene_submit_fragment"
                style="display:flex;flex-direction: column-reverse;" submit="access" method="PATCH"
                action="/auth/access/{{encodeURIComponent @root.scene.name}}" encoding="application/json"
                onsubmit="window.location.reload()">
                <form class="form-group" style="flex-grow: 1;" autocomplete="off">
                  <div class="form-group row" style="align-items: stretch">
                    <input name="username" placeholder="{{i18n "labels.username"}}" required style="flex-grow: 1"/>
                    <select name="access" aria-label="{{i18n "labels.permission"}}" style="flex-grow: 1">
                      <option disabled selected value> -- select an option -- </option>
                      {{> inputs/option selected=false value="read" text=(i18n "fields.read")}}
                      {{> inputs/option selected=false value="write" text=(i18n "fields.write")}}
                      {{> inputs/option selected=false value="admin" text=(i18n "fields.admin")}}
                    </select>
                  </div>
                </form>
                <progress slot="loader" style="position:absolute; inset: 0;backdrop-filter: blur(5px)">request in
                  progress</progress>
              </submit-fragment>
            </td>
          </tr>
          {{/if}}
        </tbody>
      </table>
    </div>

  </div>
  {{/if}}
</section>

<section>
  <h3>{{i18n "buttons.editTags" }}</h3>
  <submit-fragment submit="tags" method="PATCH" action="/scenes/{{encodeURIComponent scene.name}}" encoding="application/json" onsubmit="window.location.reload()">
    <form autocomplete="off" class="form-control">
      {{#each scene.tags}}
        <div class="form-item" style="display:flex;flex-direction:row;align-items:center; gap:.5rem;">
          <label><span class="hidden">{{@index}}</span></label>
          <span class="form-input">
            <a href="/ui/tags/{{.}}" style="flex-grow:1;">{{.}}</a>
            <label class="btn btn-danger" style="align-self: end" title="{{i18n "labels.delete"}}">
              <input type="checkbox" name="tags" checked value="{{.}}" aria-label="{{.}}" style="position:absolute;width:1px;height:1px;opacity:0;"/>
              <ui-icon name="trash"></ui-icon>
            </label>
          </span>
        </div>
      {{/each}}

      <div class="form-item">
        <label >
          {{i18n "labels.addTag" }}
        </label>
        <input id="new-tag" name="tags" list="tagSuggestions" type="text" value="" placeholder="{{i18n "fields.tag"}}" />
        <button type="submit" class="btn btn-main"><ui-icon name="plus"></ui-icon></button>
        <datalist id="tagSuggestions">
          {{#each tagSuggestions }}
            <option value="{{.}}"/>
          {{/each}}
        </datalist>
        {{!This input _has_ to have the same name as the others but we want to prevent its change event from bubbling}}
        <script type="module">
          (()=>{
            const input = document.querySelector("#new-tag");
            if(!input) return console.warn("no new tag input found in this document");
            input.addEventListener("change", (e)=>e.stopPropagation());
          })();
        </script>
      </div>
    </form>
  </submit-fragment>
</section>

<section>
  {{#if scene.archived }}
    <p>
      {{i18n "leads.archiveRestore"}}
    </p>
    <submit-fragment id="submit-restore" method="PATCH" encoding="application/json" action="/scenes/{{encodeURIComponent scene.name}}">
      <form class="form-control" style="padding: 0 0 10px 0;display:flex;justify-content:end;align-items: stetch;">
        <input type="hidden" name="archived" value="false"/>
        <input id="scene-name-input" type="text" name="name" style="flex-grow: 1;background: var(--color-element);" value=""/>
        <button role="submit" id="btn-unarchiveScene" class="btn">
          <ui-icon name="restore"></ui-icon>
          {{i18n "labels.restore"}}
        </button>
      </form>
    </submit-fragment>
    <script type="module">
      (()=>{
        const nameInput = document.querySelector("#scene-name-input");
        if(!nameInput) return console.warn("Can't find name input element");
        nameInput.value = "{{scene.name}}".replace("#{{scene.id}}", "");

        const formSubmit = document.querySelector("#submit-restore");
        if(!formSubmit) return console.warn("Can't find form-submission element");
        formSubmit.addEventListener("submit", ()=>{
          window.location.href = `/ui/scenes/${encodeURIComponent(nameInput.value)}`;
        });
      })();
      onsubmit="window.location.href= new URL('/ui/scenes/{{encodeURIComponent scene.name}}').pathname"
    </script>
  {{else}}
    <p>
      {{i18n "leads.archiveDelete"}}
    </p>
    <div style="padding: 0 0 10px 0;display:flex;justify-content:end;gap:10px;">

      <dialog id="rename-scene" style="max-width:400px" onmousedown="event.target==this && this.close()">
        <submit-fragment id="rename-scene-submit" method="PATCH" action="/scenes/{{encodeURIComponent scene.name}}" encoding="application/json">
          <h3>{{i18n "titles.rename"}}</h3>
          <p>{{i18n "leads.rename"}}</p>
          <form class="form-control">
            <div class="form-group">
              <label class="form-item">
                {{i18n "fields.name"}}
                <input id="scenename" type="text" name="name" required minlength="3" value="" placeholder="{{scene.name}}" />
              </label>
            </div>
            <div class="form-group">
              <button class="btn" type="reset" onclick="this.closest('dialog').close()">{{i18n "buttons.cancel"}}</button>
              <button type="submit" id="btn-renameScene" class="btn btn-main">
                <ui-icon name="edit"></ui-icon>
                {{i18n "buttons.rename"}}
              </button>
            </div>
          </form>
        </submit-fragment>
        <script type="module">
          (()=>{
            const submitFragment = document.querySelector("#rename-scene-submit");
            if(!submitFragment) return console.warn("Can't find fragment to submit scene rename form");
            submitFragment.addEventListener("submit", ({detail})=>{
              let name = detail.get("name");
              if(!name) return alert("Badly formatted form : no name could be found");
              window.location.replace(`/ui/scenes/${encodeURIComponent(name)}`);
            });
          })();
        </script>
      </dialog>

      <a class="btn btn-main" download="{{scene.name}}.zip"
        href="/scenes/{{encodeURIComponent scene.name}}?format=zip">
        <ui-icon name="save"></ui-icon>
        <span class="tool-text">{{i18n "buttons.download"}}</span>
      </a>

      <button class="btn" onclick="document.querySelector('#rename-scene').showModal()">
        <ui-icon name="edit"></ui-icon>
        {{i18n "buttons.rename"}}
      </button>

      <submit-fragment method="DELETE" action="/scenes/{{encodeURIComponent scene.name}}?archive=true" encoding="application/json" onsubmit="window.location.href='/ui/scenes/{{encodeURIComponent (join scene.name "#" scene.id)}}'">
        <form>
          <button role="submit" id="btn-archiveScene" class="btn">
            <ui-icon name="trash"></ui-icon>
            {{i18n "buttons.archive"}}
          </button>
        </form>
      </submit-fragment>
    </div>
  {{/if}}
</section>