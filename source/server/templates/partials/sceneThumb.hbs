{{#if thumb }}
<img src="{{thumb}}" />
{{else if (test type "==" "html")}}
<img style="background:radial-gradient(circle, var(--color-secondary) 0, var(--color-dark) 100%);"
    src="/dist/images/defaultHTMLSprite.svg" />
{{else}}
<img style="background:radial-gradient(circle, var(--color-secondary) 0, var(--color-dark) 100%);"
    src="/dist/images/defaultSprite.svg" />
{{/if}}