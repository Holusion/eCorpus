{{!scene repesentation. Give it a `Scene` interface. Optionally, provide a `compact` boolean parameter or `url` string parameter }}
<a id="scene-{{id}}" href="/ui/scenes/{{encodeURIComponent name}}/view" class="scene-card scene-card-compact">
  <div class="card-image"  title="{{i18n "labels.view"}}">
        {{> sceneThumb}}
  </div>
  <div class="scene-card-inner">
    <div class="infos">
      <div class="card-header">
        <h4 class="card-title">{{name}}</h4>
      </div>
    </div>
  </div>
</a>