<div id="scene-{{id}}" class="scene-card">
  <a class="card-image" href="/ui/scenes/{{encodeURIComponent name}}" title="{{i18n "labels.view"}}">
    {{> sceneThumb}}
  </a>
  <div class="scene-card-inner">
    <div class="infos">
      <a href="/ui/scenes/{{encodeURIComponent name}}" class="card-header">
        <h4 class="card-title" title="{{name}}">{{name}}</h4>
      </a>
      <div style="display: flex; align-items: baseline; gap: 0.4em; flex-wrap: wrap;">
        <span class="card-time">{{#if mtime}}{{dateString mtime}}{{/if}}</span>
        {{#if author}}
          <span title="{{i18n "fields.author"}}" class="btn btn-pill btn-outline {{#if (test author "==" @root.user.username)}}btn-primary{{/if}}">{{author}}</span>
        {{/if}}
      </div>
    </div>
    <div class="tools">
      {{!if a scene is shown, the user must have read access}}
      {{#if (test scene.type "==" "voyager")}}
        <a class="btn btn-main" href="/ui/scenes/{{encodeURIComponent name}}/view" title="{{i18n "leads.showScene"}}">
          <ui-icon name="eye"></ui-icon>
          <span class="tool-text">{{i18n "labels.view"}}</span>
        </a>
      {{else if (test scene.type "==" "html")}}
        <a class="btn btn-main" href="/scenes/{{encodeURIComponent name}}/index.html" title="{{i18n "leads.showScene"}}">
          <ui-icon name="eye"></ui-icon>
          <span class="tool-text">{{i18n "labels.view"}}</span>
        </a>
      {{/if}}
      {{#unless (test (test access "==" "read") "||" (test type "!=" "voyager"))}}
        <a class="tool-link" href="/ui/scenes/{{encodeURIComponent name}}/edit" title="{{i18n "leads.editScene"}}">
          <ui-icon name="edit"></ui-icon>
          <span class="tool-text">{{i18n "labels.edit"}}</span>
        </a>
      {{/unless}}
    </div>
  </div>
  {{#if select_form }}
  <input type="checkbox" form="{{select_form}}" name="id" value="{{id}}" style="position: absolute; top: 2px; left: 2px">
  {{/if}}
</div>
