
<style>
  .color-picker-overlay{
     position: absolute;
     inset: 0 2.5rem 0 1rem;
     display: flex;
     align-items: center;
     color: oklch(from var(--c, black) clamp(0, (0.6 - l) * 10000, 1) 0 0);
  }
  .table-header{
    position: sticky;
    top: 0;
    backdrop-filter: grayscale(0.5) blur(20px);
    display: flex;
    justify-content: space-between;
    z-index: 1;
    padding-top: var(--section-padding);
    .form-group{
      gap: 6px;
      .form-item{
        display: flex;
        align-items: center;
        justify-content: end;
        gap: 4px;
      }
    }
  }

  table{
    border-collapse: collapse;
    width: 100%;
    display: table;


    tr{
      > td {
        min-width: 100px;
        &:first-child {
          width: 120px;
          min-width: 120px;
          max-width: 30vw;
          white-space: nowrap;
          overflow: hidden;
          text-overflow: ellipsis;
        }
      }

      &.editing{
        .conf-key {
          color: var(--color-primary);
        }
        .conf-line{
          position: relative;
          .conf-line-form {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 4px;
            .form-item{
              flex-grow: 1;
            }
          }
        }
        .color-picker-overlay{
          pointer-events: none;
        }
      }
    }
  }
</style>

{{!-- partial for config lines --}}
{{#*inline "configRow"}}
<tr>
  <td class="conf-key text-right{{#if locked}} text-muted{{/if}}" title="{{#if locked }}{{i18n "leads.envLocked" what=key }}{{else}}{{ key }}{{/if}}">
    {{ key }}
  </td>
  <td style="position:relative">
    <div class="form-group conf-line" >
      <div class="form-item" {{#if locked}}title="{{i18n "leads.envLocked" what=key }}"{{/if}}>
        <input name="{{ key }}"
          data-default="{{ defaultValue }}"
          readonly
          autocomplete="off"
          type="{{ type }}"
          {{#if (test type "==" "checkbox")}}
            {{#if value}}checked{{/if}}
          {{else if (test type "==" "color")}}
            alpha
            value="{{ value }}"
          {{else}}
            value="{{ value }}"
            placeholder="{{ defaultValue }}"
          {{/if}}
        >
        {{#if locked}}
          <button role="none" class="btn btn-small btn-addon btn-transparent btn-danger disabled">
            <ui-icon name="key"></ui-icon>
          </button>
        {{else}}
          <button data-action="edit" role="button" class="btn btn-small btn-addon btn-transparent btn-info" title="{{i18n "labels.edit"}}">
            <ui-icon name="edit"></ui-icon>
          </button>
        {{/if}}
        {{#if (test type "==" "color")}}
          <span class="color-picker-overlay" style="--c: {{value}};">{{value}}</span>
        {{/if}}

      </div>
    </div>
  </td>
</tr>
{{/inline}}


<section>
  <form  autocomplete="off" id="config-rows-filter" class="form-control table-header" method="GET" action=".">
    <h2 id="config-title">{{i18n "titles.config"}}</h2>
    <div class="form-group" style="align-items: end;">
      <label class="form-item">
        <span class="sm-hidden">{{i18n "labels.showStatic"}}</span>
        <ui-icon class="sm-only" name="key" title="{{i18n "labels.showStatic"}}"></ui-icon>
        <input type="checkbox" name="static"  {{#if withStatic}}checked{{/if}}>
      </label>
      <label class="form-item">
        <span class="sm-hidden">{{i18n "labels.showChangedOnly"}}</span>
        <ui-icon class="sm-only" name="restore" title="{{i18n "labels.showChangedOnly"}}"></ui-icon>
        <input type="checkbox" name="changes" {{#unless withDefaults}}checked{{/unless}}>
      </label>
    </div>
    <script type="module">
      (function registerFormAutoSubmit(){
        const form = document.querySelector("#config-rows-filter");
        if(!form) return console.warn("Couldn't find config filter form");
        form.addEventListener("change", ()=>form.submit());
      })();
    </script>
  </form>
  <div class="form-control">
    <table aria-labelledby="config-title">
      <tbody>
        {{#each config }}
          {{> configRow [1] key=[0] }}
        {{/each}}
      </tbody>
    </table>
  </div>
  {{#unless config}}
  <p>{{i18n "leads.noResults"}}</p>
  {{/unless}}
</section>

<script type="module">
  /**
   * Handle "edit mode" for config lines
   */
  let activeEdit = null;

  function makeBtn(title, iconName, classes=[]) {
    const btn = document.createElement("button");
    btn.type = "button";
    btn.className = "btn btn-small";
    if(classes.length) btn.classList.add(...classes);
    btn.title = title;
    btn.innerHTML = `<ui-icon name="${iconName}"></ui-icon>`;
    return btn;
  }


  function openEdit(editBtn) {
    if (activeEdit) closeEdit();
    const container = editBtn.closest(".form-item");
    const input = container.querySelector("input");
    const tr = editBtn.closest("tr");

    const submitFrag = document.createElement("submit-fragment");
    submitFrag.setAttribute("action", "/admin/config");
    submitFrag.setAttribute("method", "PATCH");
    submitFrag.setAttribute("encoding", "application/json");
    submitFrag.setAttribute("onsubmit", "window.location.reload()");
    const form = document.createElement("form");
    form.className = "conf-line-form";

    const saveBtn  = makeBtn("{{i18n "labels.save"}}", "save", ["text-success"]);
    saveBtn.type = "submit";
    const resetBtn = makeBtn("{{i18n "labels.restore"}}", "restore", []);
    const closeBtn = makeBtn("{{i18n "labels.close"}}", "close", ["text-error"]);
    resetBtn.addEventListener("click", resetEdit);
    closeBtn.addEventListener("click", closeEdit);

    input.removeAttribute("readonly");
    editBtn.hidden = true;
    container.replaceWith(submitFrag);  // container detached, submitFrag in DOM
    form.append(container, saveBtn, resetBtn, closeBtn);
    submitFrag.append(form);

    //Synchronize overlay text color for color inputs
    const overlay = container.querySelector(".color-picker-overlay");
    const colorSync = overlay ? () => {
      overlay.style.setProperty("--c", input.value) 
      overlay.innerHTML = input.value;
    }: null;
    if (colorSync) input.addEventListener("input", colorSync);

    activeEdit = { input, container, tr, submitFrag, saveBtn, originalValue: input.value, editBtn, colorSync };
    tr.classList.add("editing");
    input.focus();
  }

  function closeEdit() {
    if (!activeEdit) return;
    const { input, container, tr, submitFrag, saveBtn, originalValue, editBtn, colorSync } = activeEdit;

    input.value = originalValue;
    input.setAttribute("readonly", "");

    if (colorSync){
      colorSync();
      input.removeEventListener("input", colorSync);
    }
  
    tr.classList.remove("editing");
    saveBtn.remove();
    submitFrag.before(container);  // move container back before submitFrag
    submitFrag.remove();
    editBtn.hidden = false;
    activeEdit = null;
  }

  function resetEdit() {
    if (!activeEdit) return;
    console.log("Reset edit", activeEdit.input.dataset.default);
    if(activeEdit.input.type =="checkbox"){
      activeEdit.input.checked = !(activeEdit.input.dataset.default == "false");
    }else{
      activeEdit.input.value = activeEdit.input.dataset.default;
    }
    if(activeEdit.colorSync){
      activeEdit.colorSync();
    }
  }


  function onOpenEdit(ev){
    if(!(ev.target instanceof HTMLButtonElement)) return;
    ev.preventDefault();
    ev.stopPropagation();
    openEdit(ev.target);
  }

  for (const btn of document.querySelectorAll("[data-action='edit']")) {
    btn.addEventListener("click", onOpenEdit);
  }
</script>

<section>
  <h3>{{i18n "titles.tools"}}</h3>
  <h4>{{i18n "leads.sendTestEmail"}}</h4>
  <submit-fragment class="form-control" action="/admin/mail/test" method="POST" encoding="application/json">
    <form class="form-control">
      <div class="form-group inline">
        <input name="to" placeholder="recipient email" value="{{user.email}}">
        <button role="submit" class="btn">Send</button>
      </div>
    </form>
  </submit-fragment>
  <h4>{{i18n "titles.previewEmail"}}</h4>
  <form id="preview-email-form" class="form-control" autocomplete="off">
    <div class="form-group inline" style="align-items: center; gap: 5px; flex-wrap: wrap;">
      <div class="form-item">
        <label>Username</label>
        <input name="username" placeholder="recipient username" value="{{user.username}}">
      </div>
      <div class="form-item" >
        <label>Template</label>
        <select name="name">
          {{> inputs/option selected=(test "fr" "==" @root.lang) value="connection_fr" text="connection_fr"}}
          {{> inputs/option selected=(test "en" "==" @root.lang) value="connection_en" text="connection_en"}}
          {{> inputs/option selected=(test "en" "==" @root.lang) value="test" text="test"}}
          
        </select>
      </div>
      <div class="form-item" >
        <label>Theme</label>
        <select name="colorScheme">
          <option selected value="light">Light</option>
          <option value="dark"> Dark</option>
        </select>
      </div>
      <button role="submit" class="btn">Fetch</button>
    </div>
  </form>

</section>

<script type="module">
  const f = document.querySelector("#preview-email-form");
  if(!f) console.error("Couldn't find email preview form");


  function onSubmitPreviewEmail(ev){
    ev.preventDefault();
    let data = new FormData(ev.target);

    const box = document.createElement("dialog");
    Object.assign(box.style, {
      maxWidth: "428px",
      width: `min(80vw, 428px)`,
      height: "60vh",
      colorScheme: `only ${data.get("colorScheme")}`,
    });
    box.onmousedown= function(){ event.target==this && this.close()};
    box.onclose = function(){
      box.parentElement.removeChild(box);
    }
    
    console.log("Name: ", ev.target)
    box.innerHTML = `<iframe allowTransparency="true" style="width:100%; height: calc(100% - 10px); border: 0px" src="/admin/mail/render/${data.get("name")}?username=${data.get("username")}"></iframe>`;
    f.insertAdjacentElement('afterend', box);
    box.showModal();
    
    return false;
  }

  f.addEventListener("submit", onSubmitPreviewEmail);
</script>