<section class="user-tokens">
  <h3>{{i18n "titles.userTokens"}}</h3>
  <p>{{i18n "leads.userTokens"}}</p>

  <form id="token-create" class="form-control" autocomplete="off">
    <div class="form-group">
      <div class="form-item">
        <label for="token-name">{{i18n "fields.name"}}</label>
        <input type="text" name="name" id="token-name" required>
      </div>
      <div class="form-item">
        <label for="token-scope">{{i18n "labels.scope"}}</label>
        <select name="scope" id="token-scope" multiple size="7">
          <option value="all" selected>all</option>
          <option value="scenes:read">scenes:read</option>
          <option value="scenes:write">scenes:write</option>
          <option value="scenes:admin">scenes:admin</option>
          <option value="scenes:create">scenes:create</option>
          <option value="tasks:read">tasks:read</option>
          <option value="tasks:write">tasks:write</option>
        </select>
      </div>
      <div class="form-item">
        <input class="btn btn-primary" type="submit" value="{{i18n "labels.create"}}">
      </div>
    </div>
  </form>

  <div id="token-secret" style="display:none">
    <p role="alert">{{i18n "leads.tokenCreated"}}</p>
    <pre><code id="token-secret-value"></code></pre>
  </div>

  <table class="list-table">
    <thead>
      <tr>
        <th>{{i18n "fields.name"}}</th>
        <th>{{i18n "labels.scope"}}</th>
        <th>client</th>
        <th>{{i18n "fields.ctime"}}</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="token-list"></tbody>
  </table>

  <script>
    (function manageTokens(){
      const list = document.querySelector("#token-list");
      const form = document.querySelector("#token-create");

      function refresh(){
        fetch("/auth/tokens", {headers: {"Accept": "application/json"}}).then(async (r)=>{
          if(!r.ok) throw new Error(await r.text());
          const tokens = await r.json();
          list.replaceChildren(...tokens.map((t)=>{
            const tr = document.createElement("tr");
            for(const text of [t.name, t.scope.join(" "), t.client ?? "—", new Date(t.created).toLocaleDateString()]){
              const td = document.createElement("td");
              td.innerText = text;
              tr.appendChild(td);
            }
            const td = document.createElement("td");
            const btn = document.createElement("button");
            btn.className = "btn btn-danger";
            btn.innerText = `{{i18n "labels.revoke"}}`;
            btn.onclick = ()=>{
              fetch(`/auth/tokens/${encodeURIComponent(t.id)}`, {method: "DELETE"}).then(refresh);
            };
            td.appendChild(btn);
            tr.appendChild(td);
            return tr;
          }));
        }).catch((e)=>console.error("Failed to fetch tokens:", e));
      }

      form.onsubmit = (ev)=>{
        ev.preventDefault();
        fetch("/auth/tokens", {
          method: "POST",
          headers: {"Content-Type": "application/json", "Accept": "application/json"},
          body: JSON.stringify({
            name: form.name.value,
            scope: Array.from(form.scope.selectedOptions).map((o)=>o.value),
          }),
        }).then(async (r)=>{
          const body = await r.json();
          if(!r.ok) throw new Error(body.message ?? JSON.stringify(body));
          //The secret is shown exactly once and never persisted client-side
          document.querySelector("#token-secret-value").innerText = body.token;
          document.querySelector("#token-secret").style.removeProperty("display");
          form.reset();
          refresh();
        }).catch((e)=>console.error("Failed to create token:", e));
        return false;
      };

      refresh();
    })();
  </script>
</section>

<section class="user-grants" style="margin-top: 2rem;">
  <h3>{{i18n "titles.authorizedApps"}}</h3>
  <p>{{i18n "leads.authorizedApps"}}</p>

  <table class="list-table">
    <thead>
      <tr>
        <th>{{i18n "labels.clientName"}}</th>
        <th>{{i18n "labels.scope"}}</th>
        <th>{{i18n "fields.ctime"}}</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="grant-list"></tbody>
  </table>

  <script>
    (function manageGrants(){
      const list = document.querySelector("#grant-list");

      function refresh(){
        fetch("/auth/oauth/grants", {headers: {"Accept": "application/json"}}).then(async (r)=>{
          if(!r.ok) throw new Error(await r.text());
          const grants = await r.json();
          if(grants.length === 0){
            const tr = document.createElement("tr");
            const td = document.createElement("td");
            td.colSpan = 4;
            td.style.textAlign = "center";
            td.innerText = `{{i18n "leads.noAuthorizedApps"}}`;
            tr.appendChild(td);
            list.replaceChildren(tr);
            return;
          }
          list.replaceChildren(...grants.map((g)=>{
            const tr = document.createElement("tr");
            for(const text of [g.client_name, g.scope.join(" "), new Date(g.created).toLocaleDateString()]){
              const td = document.createElement("td");
              td.innerText = text;
              tr.appendChild(td);
            }
            const td = document.createElement("td");
            const btn = document.createElement("button");
            btn.className = "btn btn-danger";
            btn.innerText = `{{i18n "labels.revoke"}}`;
            btn.title = `{{i18n "leads.revokeGrant"}}`;
            btn.onclick = ()=>{
              fetch(`/auth/oauth/grants/${encodeURIComponent(g.client_id)}`, {method: "DELETE"}).then(refresh);
            };
            td.appendChild(btn);
            tr.appendChild(td);
            return tr;
          }));
        }).catch((e)=>console.error("Failed to fetch grants:", e));
      }

      refresh();
    })();
  </script>
</section>
